# ─── Database ───────────────────────────────
# Local SQLite (development)
DB_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# ─── Auth ───────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ─── Server ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Email (optional) ───────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
